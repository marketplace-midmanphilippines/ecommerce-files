bel\\\" scope=\\\"row\\\">ADA Compliant</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oea5_starkcertified\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Star-K Certified</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Warranty</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of4d_warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Warranty</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2 Year Parts and Labor</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Features\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Features</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o487_sabbathmode\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Sabbath Mode</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_obc3_displaytype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Display Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">TFT Display</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o775_drawer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Drawer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Warming Drawer</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o3d3_timer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Timer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o466_temperatureprobe\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Temperature Probe</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ofb1_rotisserie\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Rotisserie</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc5e_softclosedoor\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Soft Close Door</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t</table>         </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_manuals-diagrams\\\" class=\\\"station-tabs-tab mod-last\\\" aria-controls=\\\"station-tabs-tabpanel_manuals-diagrams\\\" data-slug=\\\"manuals-diagrams\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Manuals &amp; Diagrams</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_manuals-diagrams\\\" aria-labelledby=\\\"station-tabs-tab_manuals-diagrams\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      \", \"Option1 Name\": \"Exterior Width\", \"Option1 Value\": \"48\\\"\", \"Option2 Name\": \"Gas Type\", \"Option2 Value\": \"Liquid Propane\"}, {\"Variant Name\": \"ILVE - Panoramagic Dual Fuel Ranges - UPM09FDS3SSLP\", \"Variant Inventory Tracker\": \"shopify\", \"Variant Inventory Qty\": \"10\", \"Variant SKU\": \"UPM09FDS3SSLP\", \"Variant Image\": \"https://us.ilve.com/wp-content/uploads/2024/05/UPM09FDS3SSLP_p18932-2.jpg\", \"Variant All Images\": [\"https://us.ilve.com/wp-content/uploads/2024/05/UPM09FDS3SSLP_p18932-2.jpg\", \"https://us.ilve.com/wp-content/uploads/UPM09FDS3SSLP_p18932_168064.png\", \"https://us.ilve.com/wp-content/uploads/UPM09FDS3SSLP_p18932_168065.png\", \"https://us.ilve.com/wp-content/uploads/UPM09FDS3SSLP_p18932_168066.png\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29082-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29083-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29084-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29085-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29086-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29087-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29088-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPM09FDS3SSLP_p18932_29089-1.jpg\"], \"Variant Price\": \"9900.00\", \"Variant Barcode\": \"8051202270519\", \"Variant URLS\": \"\", \"Variant Count\": \"\", \"Variant HTML\": \"      <div class=\\\"station-tabs-tabpanel station-tabs-default-tabpanel\\\" id=\\\"station-tabs-tabpanel_description\\\" aria-labelledby=\\\"station-tabs-tab_description\\\" aria-hidden=\\\"true\\\" role=\\\"tabpanel\\\">         <div class=\\\"station-tabs-tabcontent\\\"><div class=\\\"product-desc\\\"><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Panoramagic</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">A tradition of the contemporary kitchen that withstands the test of time.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It was during the fantastic 1960s that ILVE launched Panoramagic: the free-standing model that revolutionised the panorama of the domestic kitchen. Today, this tradition of Italian style and technology continues to take charge and fascinate in an updated form and with a full range of solutions to fit into any interior design.\\u00a0</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Unique design that combines the technical features of professional kitchens with the Italian culture of design, Panoramagic range cookers come in three models, all with a 4.3-inch touch screen: 48 inches with double oven and precise temperature control, 36 inches with 6 burners or with induction cooktop (hob) with 6 zones. The gas cooktops (hobs) use dual burners up to 20000 BTU as standard and a highly professional nanotechnological treatment to achieve a non-stick surface with a total black finish.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><ul style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><li>Total Black brass burners\\u00a0with non-stick nanotechnological treatment</li><li>Dual gas burners with power up to 20000 BTU as standard</li><li>Highly specialized cooktops</li><li>LED backlit knobs</li><li>Cooktop (Hob) with cast iron pan supports</li><li>4.3\\u2033\\u00a0digital touch screen control\\u00a0</li><li>Door with soft-closing system</li><li>Precise electronic temperature control</li><li>Steam discharge (moist cooking)</li><li>Temperature cooking probe</li><li>Cold oven door with triple removable glass</li></ul><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><hr><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Product Technologies</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Aesthetics is important, but it\\u2019s not all. It is essential to have the best technologies available to cook well and with pleasure.\\u00a0ILVE puts all its experience and research at your service, offering solutions that combine top-level\\u00a0performance\\u00a0and maximum simplicity, safety and user-friendliness: to always guarantee the best satisfaction.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Dual Gas Burners with Power Up to 20,000\\u00a0BTU</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Supplies optimal and perfect distribution of the flame, for all types of cooking.\\u00a0The ideal power for perfect cooking, always.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Total Black Brass Burners\\u00a0with Non-Stick Nanotechnological Treatment</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">The noble technical characteristics of brass are enriched with a nanotechnological coating that assures easy cleaning, with an elegant black finish.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooktop (Hob) with Cast Iron Pan Supports\\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">The highly durable, cast-iron pan grates provide a functional and safe support for all sorts of pots and pans.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><hr><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Oven Technologies</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Grand Size and Performance</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Any single or double combination oven you choose, will provide you with all the space you need, even for large dishes.\\u00a0</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Precise Electronic Temperature Control</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">The electronic control ensures that the temperature of the oven remains constant throughout, without fluctuating, as is the case in conventional ovens. It can be set with precision starting from 85\\u00b0F, for perfect proofing, up to 575\\u00b0F, for roasting.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Removable Triple Removable Glass Cold Door\\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Safe with children, perfectly insulated thanks to the three layers, and easy to clean.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>4.3\\u201d Digital Touch Screen Control</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Thanks to TFT technology, the display assures superior readability, displaying every function with clear and immediate graphics.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Easy Clean Enamel</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">The grease does not stick to the surface, making it\\u00a0easier to clean.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Folding Grill Coil\\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Thanks to the articulated support, the electric heating element of the grill can be lowered to clean the top part of the cavity more easily.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cool Venting and High-Density\\u00a0Oven Insulation\\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Contains the oven heat to prevent the furniture next to the oven and the kitchen from overheating.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Oven Functions. UOV 80 E3 TFT S</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><ul style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><li>Pizza function</li><li>Defrosting</li><li>Intensive cooking</li><li>Quick start</li><li>Moist intensive cooking</li><li>Fan grill cooking</li><li>Grill cooking with closed door</li><li>Cooking from above</li><li>Moist cooking from above</li><li>Cooking from below</li><li>Moist cooking from below</li><li>Static normal cooking</li><li>Moist static normal cooking</li><li>Multiple fan cooking</li><li>Multiple moist fan cooking</li><li>ECO cooking</li></ul><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><hr><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Oven Functions.</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Pizza Function</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Suitable for baking pizza, but also for bread and focaccia. The main source of heat is the lower heating element which, with the help of the other underpowered heating elements, creates an ideal situation for this type of cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Defrosting \\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Assures quick defrosting of all frozen food in general, which is quickly brought to room temperature, without altering its taste and appearance.\\u00a0</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Intensive Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It assures quick and intensive cooking with steam discharge. It is recommended to obtain a crispy result: baked potatoes and vegetables, chicken, salt crusted fish, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Quick Start</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">The quick oven preheating function allows it to reach the desired temperature in a short time and you can then choose the best suited cooking mode for the dish. It also works as quick defrosting when a low temperature is set (85\\u00b0F \\u2013 105\\u00b0F).</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Moist intensive cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It assures quick and intensive cooking with steam block. It is recommended for moist cooking: chicken cacciatore, braised meat, stewed rabbit, salt cod, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Fan Grill Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Particularly fast and deep, with significant energy savings, this function is suitable for many foods, such as: pork chop, sausages, pork or mixed kebabs, game, Roman-style gnocchi, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Grill Cooking with Closed Door</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Recommended function for quick and deep grilling, browning and roasting meat in general, fillet, Florentine steak, fish and even vegetables.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooking from Above</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Particularly suitable for browning and adding the final touch of color to many foods; it is the recommended function for burgers, pork chops, veal steaks, sole, cuttlefish, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Cooking from Above</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Ideal for browning and to add the final touch of color to many foods, while leaving them tender.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooking from Below</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">\\u200bThis is the most suitable cooking method to complete the cooking cycle, especially pastries (biscuits, meringues, leavened desserts, fruit desserts, etc.).</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Cooking from Below</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the most suitable cooking method to complete the cooking cycle, while maintaining the right level of moistness.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Static Normal Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the classic function of the electric oven, particularly suitable for cooking the following foods: pork chop, sausages, salt cod, braised meat, game, roast veal, meringues and biscuits, baked fruit, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Static Normal Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This adds more moisture to normal static cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Multiple Fan Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the function that allows different dishes to be cooked simultaneously without the smells mixing. Lasagna, croissants and brioches, tarts, cakes, etc. can be baked, thereby saving time and electricity.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Multiple Moist Fan Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This adds more moisture to multiple fan normal cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>ECO Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\">This is the function that allows you to cook with significant savings on electricity consumption. With the ECO function, cooking times adapt to slow roasting, such as: braised meats, white meats, baked pasta, delicate pastries. This cooking cycle is not recommended for frozen foods.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><hr><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>California Proposition 65</strong></p><p style=\\\"margin-bottom: 0px\\\">WARNING: Cancer and Reproductive Harm</p><p><a href=\\\"http://www.P65Warnings.ca.gov\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">www.P65Warnings.ca.gov</a></p></div>.<br><br><strong>Freight Charges May Apply</strong><br><br></div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_accessories\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_accessories\\\" data-slug=\\\"accessories\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Accessories</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_accessories\\\" aria-labelledby=\\\"station-tabs-tab_accessories\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_videos\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_videos\\\" data-slug=\\\"videos\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Videos</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_videos\\\" aria-labelledby=\\\"station-tabs-tab_videos\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-t
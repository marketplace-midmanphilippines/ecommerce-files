\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Main Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 60 M</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1ad_interiorwidth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">19 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0b4_interiorheight\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oad6_interiordepth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">16 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o5f8_secondoventype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Second Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 40 E</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob8b_secondaryinteriorwid\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob4c_secondaryinteriorhei\\\">\\t\\t\\t
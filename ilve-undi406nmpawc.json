ss=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Design Style</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Retro Style</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oe4c_trim\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Trim</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Chrome</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oca5_noblesseframes\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Noblesse Frames</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Dimensions\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Dimensions</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0e2_exteriorwidth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Exterior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">40\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o351_width\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">39 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o979_depth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Depth</th>\\t\\t\\t<td class=\\\"woocommerce
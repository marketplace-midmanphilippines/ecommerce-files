uct-attributes-item woocommerce-product-attributes-item--pa_oad6_interiordepth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">16 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o5f8_secondoventype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Second Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 40 E</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob8b_secondaryinteriorwid\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob4c_secondaryinteriorhei\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o7dd_secondaryinteriordep\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">17 1/3\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0e4_ovenracks\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Racks</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Technical Details\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Technical Details</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o168_voltage\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Voltage</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">240</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1bc_amps\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Amps</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">74</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Certifications\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Certifications</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc72_adacompliant\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">ADA Compliant</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oea5_starkcertified\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Star-K Certified</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-
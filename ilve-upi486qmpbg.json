m--pa_o1d6_ovencontroltype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Control Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Knobs</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0f3_ovendoortype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Door Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Triple Glass Door</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o6de_ovencleaningtype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Cleaning Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Easy Clean Enamel Cavities</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o468_mainoventype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Main Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 80 M</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1ad_interiorwidth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">25 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0b4_interiorheight\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oad6_inter
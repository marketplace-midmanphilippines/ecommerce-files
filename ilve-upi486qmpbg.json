ct-attributes-item woocommerce-product-attributes-item--pa_oad6_interiordepth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">16 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o5f8_secondoventype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Second Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 30 E</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob8b_secondaryinteriorwid\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">10 7/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob4c_secondaryinteriorhei\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o7dd_secondaryinteriordep\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Secondary Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">17 1/3\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0e4_ovenracks\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Racks</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Technical Details\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Technical Details</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o168_voltage\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Voltage</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">240</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1bc_amps\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Amps</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">73.8</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Certifications\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Certifications</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc72_adacompliant\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">ADA Compliant</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oea5_starkcertified\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Star-K Certified</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Warranty</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of4d_warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Warranty</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2 Year Parts and Labor</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Features\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Features</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o487_sabbathmode\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Sabbath Mode</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_obc3_displaytype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Display Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">LCD Display</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o775_drawer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Drawer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Storage Drawer</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o3d3_timer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Timer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ofb1_rotisserie\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Rotisserie</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc5e_softclosedoor\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Soft Close Door</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t</table>         </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_manuals-diagrams\\\" class=\\\"station-tabs-tab mod-last\\\" aria-controls=\\\"station-tabs-tabpanel_manuals-diagrams\\\" data-slug=\\\"manuals-diagrams\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Manuals &amp; Diagrams</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_manuals-diagrams\\\" aria-labelledby=\\\"station-tabs-tab_manuals-diagrams\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      \", \"Option1 Name\": \"Color\", \"Option1 Value\": \"RAL\", \"Option2 Name\": \"Exterior Width\", \"Option2 Value\": \"48\\\"\", \"Option3 Name\": \"Oven Door Type\", \"Option3 Value\": \"Triple Glass Door\"}, {\"Variant Name\": \"ILVE - Professional Plus II 48 inch Induction Range (Triple Glass Door, Stainless Steel) -  USA - UPI486WMPSS\", \"Variant Inventory Tracker\": \"shopify\", \"Variant Inventory Qty\": \"10\", \"Variant SKU\": \"UPI486WMPSS\", \"Variant Image\": \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420-2.jpg\", \"Variant All Images\": [\"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420-2.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1634-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1635-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1636-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1637-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1638-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1640-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1639-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1641-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1642-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1643-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/05/UPI486WMPSS_p15420_1645-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPI486WMPSS_p15420_28944-1.jpg\"], \"Variant Price\": \"10990.00\", \"Variant Barcode\": \"8051202284684\", \"Variant URLS\": \"\", \"Variant Count\": \"\", \"Variant HTML\": \"      <div class=\\\"station-tabs-tabpanel station-tabs-default-tabpanel\\\" id=\\\"station-tabs-tabpanel_description\\\" aria-labelledby=\\\"station-tabs-tab_description\\\" aria-hidden=\\\"true\\\" role=\\\"tabpanel\\\">         <div class=\\\"station-tabs-tabcontent\\\"><div class=\\\"product-desc\\\"><p style=\\\"margin-bottom: 0px\\\"><strong>Professional Plus</strong></p><p style=\\\"margin-bottom: 0px\\\">The irresistible appeal of technology and performance.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">AISI304 steel \\u2013 the raw material par excellence used in the kitchens of the best restaurants \\u2013 is the emblem of Professional Plus. A complete system of range cookers, cooktops (hobs) and hoods to design and enjoy top performances in the kitchen. Aesthetics that reflects the topmost professionalism, tailored to the space of the home.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">The Professional Plus range cookers are inspired by the kitchens of the best restaurants, bringing robustness, ergonomics and operability to the domestic space. They offer various set up options, from double ovens to gas or induction\\u00a0cooktops (hobs).</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">Available gas cooktop (hobs) ranges from 30 inch up to 60 inches with up to 8 burners and can be integrated with French top (coup de feu) and griddle. Induction cooktops (hobs) are flush-mounted, from 36 inch up to 48 inches: the latter version is equipped with no less than 6 cooking zones and the bridge function.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">The option of choosing different sizes, standard colors or upon request, the option of RAL colors, and metallic finishes, allows it to blend perfectly in any interior.</p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Residual heat indicator</li><li>Timer with automatic stop</li><li>Bridge control</li><li>Booster function</li><li>Slide controls</li><li>Child safety</li><li>Overheating and liquid spill protection</li><li>Precise electronic temperature control</li><li>Door and drawer with soft-closing system</li></ul><p></p><p style=\\\"margin-bottom: 0px\\\"><strong>Product Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">Aesthetics is important, but that\\u2019s not all. It is essential to have the best technologies available to cook well and with pleasure. ILVE puts all its experience and research at your service, offering solutions that combine top-level performance and maximum simplicity, safety and user-friendliness: to always guarantee the best satisfaction.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooktop (Hob) Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Induction Cooktop (Hob)</strong></p><p style=\\\"margin-bottom: 0px\\\">Professional Plus induction cooktops (hobs) are a safe, fast and functional way of cooking, using the latest technology combined with a sleek and refined design. Ease of cleaning, energy saving, safety, versatile temperature control and cooking speed are some of the advantages that induction provides, helping to facilitate the preparation of dishes and recipes.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Residual Heat Indicator</strong></p><p style=\\\"margin-bottom: 0px\\\">Indicates that the glass is hot and therefore, one should be careful when touching it and when placing items on it as they might be damaged.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Timer with Automatic Stop</strong></p><p style=\\\"margin-bottom: 0px\\\">Turns off the active zone once the set time elapses.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Bridge Control</strong></p><p style=\\\"margin-bottom: 0px\\\">Induction cooktops (hobs) that have this feature, provide the option of simultaneously controlling 2 adjacent zones with a single command as if they were a single zone.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Booster Function</strong></p><p style=\\\"margin-bottom: 0px\\\">Allows you to focus all the power of the induction cooktop (hob) in the preset zone, to speed up the boiling and cooking times.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Slide Controls</strong></p><p style=\\\"margin-bottom: 0px\\\">This handy \\u201ctouch control\\u201d system makes it possible, for example, to increase or decrease the operating temperature by sliding your finger from right to left or vice versa.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Child Safety</strong></p><p style=\\\"margin-bottom: 0px\\\">Once this function has been set and until it is disabled, the induction cooktop (hob) does not turn on by turning on the controls.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Overheating and Liquid Spill Protection</strong></p><p style=\\\"margin-bottom: 0px\\\">If the cooktop (hob) overheats or liquid spills occur, a safety device trips and stops operation.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Oven Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>The Ovens: Grand Size and Performance.</strong></p><p style=\\\"margin-bottom: 0px\\\">Any single or double combination oven you choose, will provide you with all the space you need, even for large dishes.\\u00a0Our 30 inch range has an oven capacity up to 4 cubic feet.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Quick Start</strong></p><p style=\\\"margin-bottom: 0px\\\">The quick oven preheating function allows it to reach the desired temperature in a short time and you can then choose the best suited cooking mode for the dish. It also works as rapid defrosting when a low temperature is set (85\\u00b0F \\u2013 105\\u00b0F).</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Precise Electronic Temperature Control</strong></p><p style=\\\"margin-bottom: 0px\\\">The electronic control ensures that the temperature of the oven remains constant throughout, without fluctuating, as is the case in conventional ovens.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Door with Soft Closing System</strong></p><p style=\\\"margin-bottom: 0px\\\">The door hinges are fitted with a shock absorber that makes closure more gradual and noiseless.</p><p style=\\\"margin-bottom: 0px\\\"><strong>Main Oven Functions. UOV 80 M</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Pizza function</li><li>Quick start</li><li>Multiple fan cooking</li><li>Intensive cooking</li><li>Fan grill cooking</li><li>Grill cooking with closed door</li><li>Cooking from above</li><li>Cooking from below</li><li>Static normal cooking</li><li></ul><p style=\\\"margin-bottom: 0px\\\"><strong>Side Oven Functions. UOV 30 E</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Grill cooking with closed door</li><li>Cooking from above</li><li>Cooking from below</li><li>Static normal cooking</li></ul><p style=\\\"margin-bottom: 0px\\\"></p><hr><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Pizza Function</strong></p><p style=\\\"margin-bottom: 0px\\\">Suitable for baking pizza, but also for bread and focaccia. The main source of heat is the lower heating element which, with the help of the other underpowered heating elements, creates an ideal situation for this type of cooking.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Quick Start</strong></p><p style=\\\"margin-bottom: 0px\\\">Reach your desired temperature in a short time with the quick preheating function, then choose the best cooking mode suited for your dish. It also works as rapid defrosting when set at a low temperature.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Multiple Fan Cooking</strong></p><p style=\\\"margin-bottom: 0px\\\">This is the function that allows different dishes to be cooked simultaneously without the smells mixing. Lasagna, croissants and brioches, tarts, cakes, etc. can be baked, thereby saving time and electricity.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Intensive Cooking</strong></p><p style=\\\"margin-bottom: 0px\\\">It assures quick and intensive cooking with steam discharge. It is recommended to obtain a crispy result: baked potatoes and vegetables, chicken, salt crusted fish, etc.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Fan Grill Cooking</strong></p><p style=\\\"margin-bottom: 0px\\\">Particularly fast and deep, with significant energy savings, this function is suitable for many foods, such as: pork chop, sausages, pork or mixed kebabs, game, Roman-style gnocchi, etc.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Grill Cooking with Closed Door</strong></p><p style=\\\"margin-bottom: 0px\\\">Recommended function for quick and deep grilling, browning and roasting meat in general, fillet, Florentine steak, fish and even vegetables.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooking from Above</strong></p><p style=\\\"margin-bottom: 0px\\\">Particularly suitable for browning and adding the final touch of color to many foods; it is the recommended function for burgers, pork chops, veal steaks, sole, cuttlefish, etc.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooking from Below</strong></p><p style=\\\"margin-bottom: 0px\\\">\\u200bThis is the most suitable cooking method to complete the cooking cycle, especially pastries (biscuits, meringues, leavened desserts, fruit desserts, etc.).</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Static Normal Cooking</strong></p><p style=\\\"margin-bottom: 0px\\\">This is the classic function of the electric oven, particularly suitable for cooking the following foods: pork chop, sausages, salt cod, braised meat, game, roast veal, meringues and biscuits, baked fruit, etc.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>California Proposition 65</strong></p><p style=\\\"margin-bottom: 0px\\\">WARNING: Cancer and Reproductive Harm</p><p style=\\\"margin-bottom: 0px\\\"><a href=\\\"http://www.P65Warnings.ca.gov\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">www.P65Warnings.ca.gov</a></p></div>.<br><br><strong>Freight Charges May Apply</strong><br><br></div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_accessories\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_accessories\\\" data-slug=\\\"accessories\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Accessories</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_accessories\\\" aria-labelledby=\\\"station-tabs-tab_accessories\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_videos\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_videos\\\" data-slug=\\\"videos\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Videos</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_videos\\\" aria-labelledby=\\\"station-tabs-tab_videos\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_configurator\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_videos\\\" data-slug=\\\"configurator\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Configurator</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_configurator\\\" aria-labell
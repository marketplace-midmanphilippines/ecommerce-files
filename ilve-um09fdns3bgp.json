k\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Child Lock</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o3d3_timer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Timer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ob99_rangelegtype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Range Leg Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Plinth</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o466_temperatureprobe\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Temperature Probe</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ofb1_rotisserie\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Rotisserie</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oe7e_continuousgrates\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Continuous Grates</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o514_digitalclock\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Digital Clock</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc5e_softclosedoor\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Soft Close Door</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_od94_delaybake\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Delay Bake</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o2ee_gasconversionkitincl\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Gas Conversion Kit Included</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ofe2_europeanconvection\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">European Convection</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t</table>         </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_manuals-diagrams\\\" class=\\\"station-tabs-tab mod-last\\\" aria-controls=\\\"station-tabs-tabpanel_manuals-diagrams\\\" data-slug=\\\"manuals-diagrams\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Manuals &amp; Diagrams</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_manuals-diagrams\\\" aria-labelledby=\\\"station-tabs-tab_manuals-diagrams\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      \", \"Option1 Name\": \"Color\", \"Option1 Value\": \"Blue Grey\", \"Option2 Name\": \"Trim\", \"Option2 Value\": \"Copper\", \"Option3 Name\": \"Exterior Width\", \"Option3 Value\": \"36\\\"\", \"Option4 Name\": \"Gas Type\", \"Option4 Value\": \"Natural Gas\", \"Option5 Name\": \"Oven Door Type\", \"Option5 Value\": \"Triple Glass Door\"}, {\"Variant Name\": \"ILVE - Majestic II Dual Fuel Ranges - UMD10FDNS3BGP\", \"Variant Inventory Tracker\": \"shopify\", \"Variant Inventory Qty\": \"10\", \"Variant SKU\": \"UMD10FDNS3BGP\", \"Variant Image\": \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345.jpg\", \"Variant All Images\": [\"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345.jpg\", \"https://us.ilve.com/wp-content/uploads/UMD10FDNS3BGP_p17345_171893.webp\", \"https://us.ilve.com/wp-content/uploads/UMD10FDNS3BGP_p17345_171894.webp\", \"https://us.ilve.com/wp-content/uploads/UMD10FDNS3BGP_p17345_171895.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_14844.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_14845.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_14846.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_14847.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_14848.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_15490.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_15491.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_15492.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_15493.webp\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_11618.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_11619.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_11620.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_11621.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/11/UMD10FDNS3BGP_p17345_32557.jpg\"], \"Variant Price\": \"9690.00\", \"Variant Barcode\": \"8051202237048\", \"Variant URLS\": \"\", \"Variant Count\": \"\", \"Variant HTML\": \"      <div class=\\\"station-tabs-tabpanel station-tabs-default-tabpanel\\\" id=\\\"station-tabs-tabpanel_description\\\" aria-labelledby=\\\"station-tabs-tab_description\\\" aria-hidden=\\\"true\\\" role=\\\"tabpanel\\\">         <div class=\\\"station-tabs-tabcontent\\\"><div class=\\\"product-desc\\\"><p style=\\\"margin-bottom: 0px\\\"><strong><strong>Majestic</strong></strong></p><p style=\\\"margin-bottom: 0px\\\">The statement range cooker which makes your kitchen unique.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">A fusion of beauty and functionality, Majestic is a bold, masterful embodiment of the ultimate range cooker. A free-standing statement-piece that blends into every setting and immediately takes center stage, with a style featuring rounded lines, crafted details, fine finishes, solutions and technologies deriving directly from the world of professional cooking.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">Majestic range cookers are appliances that decorate the home thanks to their rounded shapes forged in pure steel with painstakingly made details.\\u00a0</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">They are true gems of professionalism, designed for the kitchen in your home. They are available in a range of selected colors or in RAL Classic shades on request, combined with fine metallic finishes. Offered in a wide range of sizes (from 30 to 60 inches), they offer multiple set-up possibilities. There are three cooktop (hob) configurations to choose from: dual gas burners or fry top while the induction models are available up to the 40\\u2033 size.</p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Dual gas burners with power up to 20000 BTU as standard</li><li>Highly specialized cooktops</li><li>Precise electronic temperature control</li><li>4.3\\u2033\\u00a0Digital touch screen display</li><li>Black brass burner\\u00a0coated with non-stick<br>nanotechnological\\u00a0coating</li><li>Cooktop with cast iron pan supports.</li><li>Door and drawer with soft-closing system</li><li>Steam discharge for moist cooking</li><li>True, independent warming drawer</li><li>Cooking probe</li></ul><hr><p style=\\\"margin-bottom: 0px\\\"><strong>Product Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\">Aesthetics is important, but that\\u2019s not all. It is essential to have the best technologies available to cook well and with pleasure. ILVE puts all its experience and research at your service, offering solutions that combine top-level performance and maximum simplicity, safety and user-friendliness: to always guarantee the best satisfaction.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooktop (Hob) Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Dual Gas Burners with Power Up to 20000 BTU as Standard</strong></p><p style=\\\"margin-bottom: 0px\\\">Optimal supply and perfect distribution of the heat, for all types of cooking.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Highly Specialized Cooktops</strong></p><p style=\\\"margin-bottom: 0px\\\">Structure in AISI 304 steel with 12/10 thickness, option to choose ideal combination between a gas cooktop(hob) with up to 9 burners or induction, mixed and in various setups.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Total Black Brass Burner\\u00a0with Non-Stick Nanotechnological Coating</strong></p><p style=\\\"margin-bottom: 0px\\\">The noble technical characteristics of brass are enriched with a nanotechnological coating that assures easy cleaning, with an elegant Total Black finish.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooktop (Hob) with Cast Iron Pan Supports</strong></p><p style=\\\"margin-bottom: 0px\\\">The indestructible cast iron pan supports provide a functional and safe support for the pots.</p><p style=\\\"margin-bottom: 0px\\\"></p><hr><p style=\\\"margin-bottom: 0px\\\"><strong>Oven Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>The Ovens: Grand Size and Performance.\\u00a0</strong></p><p style=\\\"margin-bottom: 0px\\\">Any single or double combination oven you choose, will provide you with all the space you need, even for large dishes.\\u00a0Our 40-inch range has an oven capacity up to 4 cubic feet.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Precise Electronic Temperature Control</strong></p><p style=\\\"margin-bottom: 0px\\\">The electronic control ensures that the temperature of the oven remains constant throughout, without fluctuating, as is the case in conventional ovens.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>4.3\\u201d Full Touch Display</strong></p><p style=\\\"margin-bottom: 0px\\\">Thanks to TFT technology, the display assures superior readability, displaying every function with clear and immediate graphics.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>TFT Display User-Friendly, Comprehensive and High Resolution.\\u00a0</strong></p><p style=\\\"margin-bottom: 0px\\\">Simply touch the large display with one finger to control all the functions of the single oven or of the two ovens, with a single device. Temperature, timer, and automatic cooking start and end programmer: everything is controlled with one move and at a glance.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Door with Soft Closing System</strong></p><p style=\\\"margin-bottom: 0px\\\">The door hinges are fitted with a shock absorber that makes closure more gradual and noiseless.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Warming Drawer with Soft-Closing System</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooking Probe</strong></p><p style=\\\"margin-bottom: 0px\\\">An essential accessory to check the temperature at the core, for example in meat cuts.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Steam Discharge (Moist Cooking)</strong></p><p style=\\\"margin-bottom: 0px\\\">Thanks to this system, the vapors are removed from inside the cavity, allowing you to choose a drier or more moist cooking. This way, you can achieve a crispy baked dish, or a soft and juicy roast.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Temperature from 85\\u00b0 to 575\\u00b0 F</strong></p><p style=\\\"margin-bottom: 0px\\\">From proofing to cooking, roasting to low temperature, ILVE ovens allow you to prepare complex and sophisticated recipes very easily, with perfect results.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Tangential Cooling Ventilation and High-Density Insulation\\u00a0</strong></p><p style=\\\"margin-bottom: 0px\\\">Prevents the furniture next to the oven and the kitchen from overheating.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Folding Grill Coil for Complete Cleaning</strong></p><p style=\\\"margin-bottom: 0px\\\">Thanks to the articulated support, the electric heating element of the grill can be lowered to clean the top part of the cavity more easily.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Easy Clean Enamel</strong></p><p style=\\\"margin-bottom: 0px\\\">The grease does not stick to the surface and can therefore be cleaned more easily.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Primary Oven functions. UOV 60 E3 TFT S</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Pizza function</li><li>Defrosting</li><li>Intensive cooking</li><li>Quick start</li><li>Moist intensive cooking</li><li>Fan grill cooking</li><li>Grill cooking with closed door</li><li>Cooking from above</li><li>Moist cooking from above</li><li>Cooking from below</li><li>Moist cooking from below</li><li>Static normal cooking</li><li>Moist static normal cooking</li><li>Multiple fan cooking</li><li>Multiple moist fan cooking</li><li>ECO cooking</li></ul><p><strong>Secondary Oven functions.\\u00a0UOV 30 E3 TFT</strong></p><ul><li>Grill cooking with closed door</li><li>Cooking from above</li><li>Cooking from below</li><li>Static normal cooking</li><li>ECO cooking</li></ul><hr><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Oven Functions</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong><br>Pizza Function</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Suitable for baking pizza, but also for bread and focaccia. The main source of heat is the lower heating element which, with the help of the other underpowered heating elements, creates an ideal situation for this type of cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Defrosting \\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Assures quick defrosting of all frozen food in general, which is quickly brought to room temperature, without altering its taste and appearance.\\u00a0</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Intensive cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It assures quick and intensive cooking with steam discharge. It is recommended to obtain a crispy result: baked potatoes and vegetables, chicken, salt crusted fish, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Quick start</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\">Reach your desired temperature in a short time with the quick preheating function, then choose the best cooking mode suited for your dish. It also works as rapid defrosting when set at a low temperature.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Intensive Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It assures quick and intensive cooking with steam block. It is recommended for moist cooking: chicken cacciatore, braised meat, stewed rabbit, salt cod, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Fan Grill Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Particularly fast and deep, with significant energy savings, this function is suitable for many foods, such as: pork chop, sausages, pork or mixed kebabs, game, Roman-style gnocchi, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Grill Cooking with Closed Door</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Recommended function for quick and deep grilling, browning and roasting meat in general, fillet, Florentine steak, fish and even vegetables.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooking from Above</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Particularly suitable for browning and adding the final touch of color to many foods; it is the recommended function for burgers, pork chops, veal steaks, sole, cuttlefish, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Cooking from Above</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Ideal for browning and to add the final touch of colour to many foods, while leaving them tender.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooking from Below</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">\\u200bThis is the most suitable cooking method to complete the cooking cycle, especially pastries (biscuits, meringues, leavened desserts, fruit desserts, etc.).</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Cooking from Below</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the most suitable cooking method to complete the cooking cycle, while maintaining the right level of moistness.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Static Normal Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the classic function of the electric oven, particularly suitable for cooking the following foods: pork chop, sausages, salt cod, braised meat, game, roast veal, meringues and biscuits, baked fruit, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Static Normal Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This adds more moisture to normal static cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Multiple Fan Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the function that allows different dishes to be cooked simultaneously without the smells mixing. Lasagna, croissants and brioches, tarts, cakes, etc. can be baked, thereby saving time and electricity.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Multiple Moist Fan Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This adds more moisture to multiple fan normal cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>ECO Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the function that allows you to cook with significant savings on electricity consumption. With the ECO function, cooking times adapt to slow roasting, such as: braised meats, white meats, baked pasta, delicate pastries. This cooking cycle is not recommended for frozen foods.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>California Proposition 65</strong></p><p style=\\\"margin-bottom: 0px\\\">WARNING: Cancer and Reproductive Harm</p><p style=\\\"margin-bottom: 0px\\\"><strong><a href=\\\"http://www.P65Warnings.ca.gov\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">w<span style=\\\"font-weight: normal\\\">ww.P65Warnings.ca.gov</span></a></strong></p><p class=\\\"o_default_snippet_text\\\" style=\\\"text-align: justify;margin-bottom: 0px\\\"></p></div>.<br><br><strong>Freight Charges May Apply</strong><br><br></div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_accessories\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_accessories\\\" data-slug=\\\"accessories\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Accessories</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_accessories\\\" aria-labelledby=\\\"station-tabs-tab_accessories\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_videos\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_videos\\\" data-slug=\\\"videos\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"s
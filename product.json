ibutes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oea5_starkcertified\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Star-K Certified</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Warranty</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of4d_warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Warranty</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2 Year Parts and Labor</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Features\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Features</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o487_sabbathmode\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Sabbath Mode</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_obc3_displaytype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Display Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">TFT Display</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o775_drawer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Drawer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Warming Drawer</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o3d3_timer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Timer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o466_temperatureprobe\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Temperature Probe</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ofb1_rotisserie\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Rotisserie</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc5e_softclosedoor\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Soft Close Door</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t</table>         </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_manuals-diagrams\\\" class=\\\"station-tabs-tab mod-last\\\" aria-controls=\\\"station-tabs-tabpanel_manuals-diagrams\\\" data-slug=\\\"manuals-diagrams\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Manuals &amp; Diagrams</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_manuals-diagrams\\\" aria-labelledby=\\\"station-tabs-tab_manuals-diagrams\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">            <div class=\\\"woocommerce-Tabs-panel woocommerce-Tabs-panel--documents panel entry-content wc-tab\\\" id=\\\"tab-documents\\\" role=\\\"tabpanel\\\" aria-labelledby=\\\"tab-title-documents\\\">\\t\\t\\t\\t<ul class=\\\"document-list\\\"><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_4474.pdf\\\" target=\\\"_blank\\\">Cleaning &amp; Maintenance.pdf</a></li><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_97.pdf\\\" target=\\\"_blank\\\">ILVE USA Brochure.pdf</a></li><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_6931.pdf\\\" target=\\\"_blank\\\">ILVE USA Panoramagic Order Form.pdf</a></li><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_7645.pdf\\\" target=\\\"_blank\\\">ILVE-Warranty.pdf</a></li><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_98.pdf\\\" target=\\\"_blank\\\">Panoramagic Manual.pdf</a></li><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_7547.pdf\\\" target=\\\"_blank\\\">Panoramagic-Overview.pdf</a></li><li><i class=\\\"fa fa-file-pdf-o\\\" aria-hidden=\\\"true\\\"></i> <a href=\\\"/static/product_documents/UPMI09S3MK-60_10428.\\\" target=\\\"_blank\\\">Spec-Sheet</a></li></ul>\\t\\t\\t</div>         </div>      </div>      \", \"Option1 Name\": \"Color\", \"Option1 Value\": null}, {\"Variant Name\": \"ILVE - Panoramagic 36 inch Induction Range in Stainless Steel -  USA - UPMI09S3SS\", \"Variant Inventory Tracker\": \"shopify\", \"Variant Inventory Qty\": \"10\", \"Variant SKU\": \"UPMI09S3SS\", \"Variant Image\": \"https://us.ilve.com/wp-content/uploads/2024/05/UPMI09S3SS_p15510-2.jpg\", \"Variant All Images\": [\"https://us.ilve.com/wp-content/uploads/2024/05/UPMI09S3SS_p15510-2.jpg\", \"https://us.ilve.com/wp-content/uploads/UPMI09S3SS_p15510_168054.png\", \"https://us.ilve.com/wp-content/uploads/UPMI09S3SS_p15510_168055.png\", \"https://us.ilve.com/wp-content/uploads/UPMI09S3SS_p15510_168056.png\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15350-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15351-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15352-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15353-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15354-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15355-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/07/UPMI09S3SS_p15510_15356-1.jpg\", \"https://us.ilve.com/wp-content/uploads/2024/09/UPMI09S3SS_p15510_29108-1.jpg\"], \"Variant Price\": \"10500.00\", \"Variant Barcode\": null, \"Variant URLS\": \"\", \"Variant Count\": \"\", \"Variant HTML\": \"      <div class=\\\"station-tabs-tabpanel station-tabs-default-tabpanel\\\" id=\\\"station-tabs-tabpanel_description\\\" aria-labelledby=\\\"station-tabs-tab_description\\\" aria-hidden=\\\"true\\\" role=\\\"tabpanel\\\">         <div class=\\\"station-tabs-tabcontent\\\"><div class=\\\"product-desc\\\"><p style=\\\"margin-bottom: 0px\\\"><section style=\\\"background-image: none\\\" data-name=\\\"Picture\\\" data-snippet=\\\"s_picture\\\" class=\\\"s_picture pt48 o_colored_level o_cc o_cc1 pb0\\\"><div class=\\\"container\\\"><p style=\\\"margin-bottom: 0px\\\"><strong><font class=\\\"bg-black\\\">Panoramagic</font></strong></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">A tradition of the contemporary kitchen that withstands the test of time.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">It was during the fantastic 1960s that ILVE launched Panoramagic: the free-standing model that revolutionized the panorama of the domestic kitchen. Today, this tradition of Italian style and technology continues to take charge and fascinate in an updated form and with a full range of solutions to fit into any interior design.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Unique design that combines the technical features of professional kitchens with the Italian culture of design, Panoramagic range cookers come in three models, all with a 4.3-inch touch screen: 48 inches with double oven and precise temperature control, 36 inches with 6 burners or with induction cooktop (hob) with 6 zones.\\u00a0</font></p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li><font class=\\\"bg-black\\\">Residual heat indicator</font></li><li><font class=\\\"bg-black\\\">Timer with automatic stop</font></li><li><font class=\\\"bg-black\\\">Bridge control</font></li><li><font class=\\\"bg-black\\\">Booster function</font></li><li><font class=\\\"bg-black\\\">Slide controls</font></li><li><font class=\\\"bg-black\\\">Child safety</font></li><li><font class=\\\"bg-black\\\">Overheating and liquid spill protection</font></li><li><font class=\\\"bg-black\\\">Cold door with triple removable glass</font></li><li><font class=\\\"bg-black\\\">4.3\\u2033\\u00a0digital touch screen control</font></li><li><font class=\\\"bg-black\\\">Precise electronic temperature control</font></li><li><font class=\\\"bg-black\\\">Steam discharge (moist cooking)</font></li><li><font class=\\\"bg-black\\\">Door and drawer with soft-closing system</font></li><li><font class=\\\"bg-black\\\">Cold oven door with triple removable glass</font></li><li><font class=\\\"bg-black\\\">Quick start</font></li></ul><p></p><hr><p><font class=\\\"bg-black\\\"><strong><br>Product Technologies</strong></font></p><p><font class=\\\"bg-black\\\">Aesthetics is important, but it\\u2019s not all. It is essential to have the best technologies available to cook well and with pleasure.\\u00a0ILVE puts all its experience and research at your service, offering solutions that combine top-level\\u00a0performance\\u00a0and maximum simplicity, safety and user-friendliness: to always guarantee the best satisfaction.</font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Induction Cooktop (Hob)</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Panoramagic\\u00a0induction hobs are a safe, fast and functional way of cooking, using the latest technology combined with a sleek and refined design. Ease of cleaning, energy saving, safety, versatile temperature control and cooking speed are some of the advantages that induction have to offer.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Booster Function</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Allows you to focus all the power of the induction hob in the preset zone, to speed up the boiling and cooking times.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Residual Heat Indicator\\u00a0</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Indicates that the glass is hot and therefore, one should be careful when touching it and when placing items on it as they might be damaged.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Bridge Control</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Induction hobs that have this feature, provide the option of simultaneously controlling 2 adjacent zones with a single command as if they were a single zone.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Overheating and Liquid Spill Protection</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">If the hob overheats or liquid spills occur, a safety device trips and stops operation.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Door with Soft Closing System</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">The door hinges are fitted with a shock absorber that makes closure more gradual and noiseless.</font></p><p></p><hr><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Oven Technologies</strong></font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Grand Size and Performance</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Any single or double combination oven you choose, will provide you with all the space you need, even for large dishes. Our 36-inch range has an oven capacity of as much as 4 cubic feet!</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Precise Electronic Temperature Control</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">The electronic control ensures that the temperature of the oven remains constant throughout, without fluctuating, as is the case in conventional ovens. It can be set with precision starting from 85\\u00b0F, for perfect proofing, up to 575\\u00b0F, for roasting.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Removable Triple Removable Glass Cold Door\\u00a0</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Safe with children, perfectly insulated thanks to the three layers, and easy to clean.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>4.3\\u201d Digital Touch Screen Control</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Thanks to TFT technology, the display assures superior readability, displaying every function with clear and immediate graphics.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Easy Clean Enamel</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">The grease does not stick to the surface, making it\\u00a0easier to clean.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Folding Grill Coil Heating Oven Element</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Thanks to the articulated support, the electric heating element of the grill can be lowered to clean the top part of the cavity more easily.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Cool Venting and High-Density Oven Insulation\\u00a0</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Contains the oven heat to prevent the furniture next to the oven and the kitchen from overheating.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Oven Functions. UOV 80 E3 TFT S</strong></font></p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li><font class=\\\"bg-black\\\">Pizza function</font></li><li><font class=\\\"bg-black\\\">Defrosting</font></li><li><font class=\\\"bg-black\\\">Intensive cooking</font></li><li><font class=\\\"bg-black\\\">Quick start</font></li><li><font class=\\\"bg-black\\\">Moist intensive cooking</font></li><li><font class=\\\"bg-black\\\">Fan grill cooking</font></li><li><font class=\\\"bg-black\\\">Grill cooking with closed door</font></li><li><font class=\\\"bg-black\\\">Cooking from above</font></li><li><font class=\\\"bg-black\\\">Moist cooking from above</font></li><li><font class=\\\"bg-black\\\">Cooking from below</font></li><li><font class=\\\"bg-black\\\">Moist cooking from below</font></li><li><font class=\\\"bg-black\\\">Static normal cooking</font></li><li><font class=\\\"bg-black\\\">Moist static normal cooking</font></li><li><font class=\\\"bg-black\\\">Multiple fan cooking</font></li><li><font class=\\\"bg-black\\\">Multiple moist fan cooking</font></li><li><font class=\\\"bg-black\\\">ECO cooking<p></p></font></li></ul><hr><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Oven Functions</strong>\\u200b</font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong><br>Pizza Function</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Suitable for baking pizza, but also for bread and focaccia. The main source of heat is the lower heating element which, with the help of the other underpowered heating elements, creates an ideal situation for this type of cooking.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Intensive Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">It assures quick and intensive cooking with steam discharge. It is recommended to obtain a crispy result: baked potatoes and vegetables, chicken, salt crusted fish, etc.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Moist Intensive Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">It assures quick and intensive cooking with steam block. It is recommended for moist cooking: chicken cacciatore, braised meat, stewed rabbit, salt cod, etc.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Grill Cooking with Closed Door</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Recommended function for quick and deep grilling, browning and roasting meat in general, fillet, Florentine steak, fish and even vegetables.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Moist Cooking from Above</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Ideal for browning and to add the final touch of color to many foods, while leaving them tender.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Moist Cooking from Below</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">This is the most suitable cooking method to complete the cooking cycle, while maintaining the right level of moistness.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Moist Static Normal Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">This adds more moisture to normal static cooking.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Multiple Moist Fan Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">This adds more moisture to multiple fan normal cooking.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Defrosting \\u00a0</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Assures quick defrosting of all frozen food in general, which is quickly brought to room temperature, without altering its taste and appearance. \\u00a0</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Quick Start</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">The quick oven preheating function allows it to reach the desired temperature in a short time and you can then choose the best suited cooking mode for the dish. It also works as quick defrosting when a low temperature is set (85\\u00b0F \\u2013 105\\u00b0F).</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Fan Grill Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Particularly fast and deep, with significant energy savings, this function is suitable for many foods, such as: pork chop, sausages, pork or mixed kebabs, game, Roman-style gnocchi, etc.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Cooking from Above</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">Particularly suitable for browning and adding the final touch of color to many foods; it is the recommended function for burgers, pork chops, veal steaks, sole, cuttlefish, etc.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Cooking from Below</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">\\u200bThis is the most suitable cooking method to complete the cooking cycle, especially pastries (biscuits, meringues, leavened desserts, fruit desserts, etc.).</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Static Normal Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">This is the classic function of the electric oven, particularly suitable for cooking the following foods: pork chop, sausages, salt cod, braised meat, game, roast veal, meringues and biscuits, baked fruit, etc.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>Multiple Fan Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">This is the function that allows different dishes to be cooked simultaneously without the smells mixing. Lasagna, croissants and brioches, tarts, cakes, etc. can be baked, thereby saving time and electricity.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>ECO Cooking</strong></font></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\">This is the function that allows you to cook with significant savings on electricity consumption. With the ECO function, cooking times adapt to slow roasting, such as: braised meats, white meats, baked pasta, delicate pastries. This cooking cycle is not recommended for frozen foods.</font></p><p style=\\\"margin-bottom: 0px\\\"></p><hr><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><font class=\\\"bg-black\\\"><strong>California Proposition 65<br></strong>WARNING: Cancer and Reproductive Harm</font><br><a href=\\\"http://www.P65Warnings.ca.gov\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\"><font class=\\\"bg-black\\\">www.P65Warnings.ca.gov</font></a></p></div></section></p></div>.<br><br><strong>Freight Charges May Apply</strong><br><br></div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_accessories\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_ac
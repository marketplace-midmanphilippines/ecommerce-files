utes-item__label\\\" scope=\\\"row\\\"><br><b>Cooking Surface</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ocf7_cooktopconfiguration\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Cooktop Configuration</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Induction</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o9f0_burnerelementtype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Burner/Element Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Induction Element</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0e1_numberofburnerseleme\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Number of Burners/Elements</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">5</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o019_grill\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Grill</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of27_griddle\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Griddle</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0e0_frenchtop\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">French Top</th>\\t\\
abel\\\" scope=\\\"row\\\">Oven Cleaning Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Easy Clean Enamel Cavities</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o468_mainoventype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Main Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 80 E3 TFT S</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1ad_interiorwidth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">26 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0b4_interiorheight\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oad6_interiordepth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">16 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Technical Details\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Technical Details</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o168_voltage\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"ro
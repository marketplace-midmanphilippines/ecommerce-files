product-attributes-item woocommerce-product-attributes-item--Style\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Style</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o67b_style\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Style</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Freestanding</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o7e4_controllocation\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Control Location</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Front</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Capacity\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Capacity</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o40d_totalcapacitycu-ft\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Total Capacity (cu. ft.)</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">3.5</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oa03_numberofovens\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Number of Ovens</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Single Oven</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o615_mainovencapacitycu\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Main Oven Capacity (cu. ft.)</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">3.5</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Cooking Surface\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Cooking Surface</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ocf7_cooktopconfiguration\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Cooktop Configuration</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Induction</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o9f0_burnerelementtype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Burner/Element Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Induction Element</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0e1_numberofburnerseleme\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Number of Burners/Elements</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">5</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o019_grill\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Grill</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">No</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of27_griddle\\\">\\t\\t\\t<th class=\\\"woocommerce-product-at
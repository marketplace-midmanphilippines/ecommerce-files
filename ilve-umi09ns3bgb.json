pecification\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_specification\\\" data-slug=\\\"specification\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Specification</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_specification\\\" aria-labelledby=\\\"station-tabs-tab_specification\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">               <table class=\\\"woocommerce-product-attributes shop_attributes\\\" aria-label=\\\"Product Details\\\">\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of67_brand\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Brand</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">ILVE</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o338_series\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Series</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Majestic II</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o53b_appliancecategory\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Appliance Category</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Range</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Appearance\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Appearance</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o543_
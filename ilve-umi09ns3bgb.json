tes-item__value\\\">35 7/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o979_depth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">29\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of7c_height\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">38 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o82d_depthwithdooropeneda\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Depth with Door Opened at 90 Degrees</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">42 7/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o4a9_productweightlbs\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Product Weight (lbs)</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">248</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Fuel Type\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Fuel Type</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oee8_fueltype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Fuel Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Electric</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"wo
row\\\">Burner/Element Output N5</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">1800 Watts</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Oven\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Oven</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1d6_ovencontroltype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Control Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">TFT Electronic Touchscreen</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0f3_ovendoortype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Door Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Solid Door</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o6de_ovencleaningtype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Cleaning Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Easy Clean Enamel Cavities</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o468_mainoventype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Main Oven Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">UOV 80 E3 TFT S</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1ad_interiorwidth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Width</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">26 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0b4_interiorheight\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Height</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">14 3/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oad6_interiordepth\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Interior Depth</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">16 1/8\\u2033</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Technical Details\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Technical Details</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o168_voltage\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Voltage</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">240</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1bc_amps\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Amps</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">66</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Certifications\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Certifications</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oea5_starkcertified\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Star-K Certified</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Warranty</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_of4d_warranty\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Warranty</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2 Year Parts and Labor</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Features\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Features</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o487_sabbathmode\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Sabbath Mode</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_obc3_displaytype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Display Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">TFT Display</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o764_numberofracks\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Number of Racks</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o775_drawer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Drawer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Warming Drawer</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o3d3_timer\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Timer</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o466_temperatureprobe\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Temperature Probe</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_ofb1_rotisserie\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Rotisserie</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_oc5e_softclosedoor\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Soft Close Door</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Yes</td>\\t\\t</tr>\\t</table>         </div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_manuals-diagrams\\\" class=\\\"station-tabs-tab mod-last\\\" aria-controls=\\\"station-tabs-tabpanel_manuals-diagrams\\\" data-slug=\\\"manuals-diagrams\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Manuals &amp; Diagrams</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_manuals-diagrams\\\" aria-labelledby=\\\"station-tabs-tab_manuals-diagrams\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">                     </div>      </div>      \", \"Option1 Name\": \"Color\", \"Option1 Value\": \"Emerald Green\", \"Option2 Name\": \"Trim\", \"Option2 Value\": \"Chrome\", \"Option3 Name\": \"Oven Door Type\", \"Option3 Value\": \"Solid Door\"}, {\"Variant Name\": \"ILVE - Majestic II Electric Range - UMI09QNS3EGG\", \"Variant Inventory Tracker\": \"shopify\", \"Variant Inventory Qty\": \"10\", \"Variant SKU\": \"UMI09QNS3EGG\", \"Variant Image\": \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599.jpg\", \"Variant All Images\": [\"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_170359.webp\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_170360.webp\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_170361.webp\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_147675-1.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_147676-1.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_147677-1.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_147678-1.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_147679-1.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_147680-1.jpg\", \"https://us.ilve.com/wp-content/uploads/UMI09QNS3EGG_p13599_11154.jpg\"], \"Variant Price\": \"9390.00\", \"Variant Barcode\": \"8051202223362\", \"Variant URLS\": \"\", \"Variant Count\": \"\", \"Variant HTML\": \"      <div class=\\\"station-tabs-tabpanel station-tabs-default-tabpanel\\\" id=\\\"station-tabs-tabpanel_description\\\" aria-labelledby=\\\"station-tabs-tab_description\\\" aria-hidden=\\\"true\\\" role=\\\"tabpanel\\\">         <div class=\\\"station-tabs-tabcontent\\\"><div class=\\\"product-desc\\\"><p style=\\\"margin-bottom: 0px\\\"><strong>Majestic\\u00a0</strong></p><p style=\\\"margin-bottom: 0px\\\">The statement range cooker which makes your kitchen unique.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">A fusion of beauty and functionality, Majestic is a bold, masterful embodiment of the ultimate range cooker. A free-standing statement-piece that blends into every setting and immediately takes center stage, with a style featuring rounded lines, crafted details, fine finishes, solutions and technologies deriving directly from the world of professional cooking.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">Majestic range cookers are appliances that decorate the home thanks to their rounded shapes forged in pure steel with painstakingly made details.\\u00a0</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">They are true gems of professionalism, designed for the kitchen in your home. They are available in a range of selected colors or in RAL Classic shades on request, combined with fine metallic finishes. Offered in a wide range of sizes (from 30 to 60 inches), they offer multiple set-up possibilities.\\u00a0</p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Residual heat indicator</li><li>Timer with automatic stop</li><li>Bridge control</li><li>Booster function</li><li>Slide controls</li><li>Child safety</li><li>Display 4.3\\u2033 full touch</li><li>Overheating and liquid spill protection</li><li>Precise electronic temperature control</li><li>Door and drawer with soft-closing system</li><li>Quick start</li></ul><p style=\\\"margin-bottom: 0px\\\"></p><hr><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Product Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\">Aesthetics is important, but that\\u2019s not all. It is essential to have the best technologies available to cook well and with pleasure. ILVE puts all its experience and research at your service, offering solutions that combine top-level performance and maximum simplicity, safety and user-friendliness: to always guarantee the best satisfaction.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooktop (Hob) Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Induction Cooktop (Hob)</strong></p><p style=\\\"margin-bottom: 0px\\\">Majestic induction cooktops (hobs) are a safe, fast and functional way of cooking, using the latest technology combined with a sleek and refined design. Ease of cleaning, energy saving, safety, versatile temperature control and cooking speed are some of the advantages that induction provides, helping to facilitate the preparation of dishes and recipes.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Residual Heat Indicator</strong></p><p style=\\\"margin-bottom: 0px\\\">Indicates that the glass is hot and therefore, one should be careful when touching it and when placing items on it as they might be damaged.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Timer with Automatic Stop</strong></p><p style=\\\"margin-bottom: 0px\\\">Turns off the active zone once the set time elapses.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Bridge Control</strong></p><p style=\\\"margin-bottom: 0px\\\">Induction cooktops (hobs) that have this feature, provide the option of simultaneously controlling 2 adjacent zones with a single command as if they were a single zone.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Booster Function</strong></p><p style=\\\"margin-bottom: 0px\\\">Allows you to focus all the power of the induction cooktop (hob) in the preset zone, to speed up the boiling and cooking times.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Slide Controls</strong></p><p style=\\\"margin-bottom: 0px\\\">This handy \\u201ctouch control\\u201d system makes it possible, for example, to increase or decrease the operating temperature by sliding your finger from right to left or vice versa.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Child Safety</strong></p><p style=\\\"margin-bottom: 0px\\\">Once this function has been set and until it is disabled, the induction cooktop (hob) does not turn on by turning on the controls.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Overheating and Liquid Spill Protection</strong></p><p style=\\\"margin-bottom: 0px\\\">If the cooktop (hob) overheats or liquid spills occur, a safety device trips and stops operation.</p><hr><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Oven Technologies</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>The Ovens: Grand Size and Performance.</strong></p><p style=\\\"margin-bottom: 0px\\\">Any single or double combination oven you choose, will provide you with all the space you need, even for large dishes.\\u00a0Our 36-inch range has an oven capacity up to 4 cubic feet.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Precise Electronic Temperature Control</strong></p><p style=\\\"margin-bottom: 0px\\\">The electronic control ensures that the temperature of the oven remains constant throughout, without fluctuating, as is the case in conventional ovens.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>4.3\\u201d Full Touch Display</strong></p><p style=\\\"margin-bottom: 0px\\\">Thanks to TFT technology, the display assures superior readability, displaying every function with clear and immediate graphics.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>TFT Display User-Friendly, Comprehensive and High Resolution.\\u00a0</strong></p><p style=\\\"margin-bottom: 0px\\\">Simply touch the large display with one finger to control all the functions of the single oven or of the two ovens, with a single device. Temperature, timer, and automatic cooking start and end programmer: everything is controlled with one move and at a glance.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Door with Soft Closing System</strong></p><p style=\\\"margin-bottom: 0px\\\">The door hinges are fitted with a shock absorber that makes closure more gradual and noiseless.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Warming Drawer with Soft-Closing System</strong></p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Cooking Probe</strong></p><p style=\\\"margin-bottom: 0px\\\">An essential accessory to check the temperature at the core, for example in meat cuts.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Steam Discharge (Moist Cooking)</strong></p><p style=\\\"margin-bottom: 0px\\\">Thanks to this system, the vapors are removed from inside the cavity, allowing you to choose a drier or more moist cooking. This way, you can achieve a crispy baked dish, or a soft and juicy roast.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Temperature from 85\\u00b0 to 575\\u00b0 F</strong></p><p style=\\\"margin-bottom: 0px\\\">From proofing to cooking, roasting to low temperature, ILVE ovens allow you to prepare complex and sophisticated recipes very easily, with perfect results.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Tangential Cooling Ventilation and High Density Insulation\\u00a0</strong></p><p style=\\\"margin-bottom: 0px\\\">Prevents the furniture next to the oven and the kitchen from overheating.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Folding Grill Coil for Complete Cleaning</strong></p><p style=\\\"margin-bottom: 0px\\\">Thanks to the articulated support, the electric heating element of the grill can be lowered to clean the top part of the cavity more easily.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Easy Clean Enamel</strong></p><p style=\\\"margin-bottom: 0px\\\">The grease does not stick to the surface and can therefore be cleaned more easily.</p><p style=\\\"margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>Oven Functions.\\u00a0UOV 80 E3 TFT S</strong></p><p></p><p style=\\\"margin-bottom: 0px\\\"></p><ul style=\\\"margin-bottom: 0px\\\"><li>Pizza function</li><li>Defrosting</li><li>Intensive cooking</li><li>Quick start</li><li>Moist intensive cooking</li><li>Fan grill cooking</li><li>Grill cooking with closed door</li><li>Cooking from above</li><li>Moist cooking from above</li><li>Cooking from below</li><li>Moist cooking from below</li><li>Static normal cooking</li><li>Moist static normal cooking</li><li>Multiple fan cooking</li><li>Multiple moist fan cooking</li><li>ECO cooking</li></ul><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><hr><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Pizza Function</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Suitable for baking pizza, but also for bread and focaccia. The main source of heat is the lower heating element which, with the help of the other underpowered heating elements, creates an ideal situation for this type of cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"><strong>Defrosting \\u00a0</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Assures quick defrosting of all frozen food in general, which is quickly brought to room temperature, without altering its taste and appearance.\\u00a0</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Intensive Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It assures quick and intensive cooking with steam discharge. It is recommended to obtain a crispy result: baked potatoes and vegetables, chicken, salt crusted fish, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Quick Start</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\">Reach your desired temperature in a short time with the quick preheating function, then choose the best cooking mode suited for your dish. It also works as rapid defrosting when set at a low temperature.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Intensive Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">It assures quick and intensive cooking with steam block. It is recommended for moist cooking: chicken cacciatore, braised meat, stewed rabbit, salt cod, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Fan Grill Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Particularly fast and deep, with significant energy savings, this function is suitable for many foods, such as: pork chop, sausages, pork or mixed kebabs, game, Roman-style gnocchi, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Grill Cooking with Closed Door</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Recommended function for quick and deep grilling, browning and roasting meat in general, fillet, Florentine steak, fish and even vegetables.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooking from Above</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Particularly suitable for browning and adding the final touch of color to many foods; it is the recommended function for burgers, pork chops, veal steaks, sole, cuttlefish, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Cooking from Above</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">Ideal for browning and to add the final touch of colour to many foods, while leaving them tender.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Cooking from Below</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">\\u200bThis is the most suitable cooking method to complete the cooking cycle, especially pastries (biscuits, meringues, leavened desserts, fruit desserts, etc.).</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Cooking from Below</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the most suitable cooking method to complete the cooking cycle, while maintaining the right level of moistness.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Static Normal Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the classic function of the electric oven, particularly suitable for cooking the following foods: pork chop, sausages, salt cod, braised meat, game, roast veal, meringues and biscuits, baked fruit, etc.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Moist Static Normal Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This adds more moisture to normal static cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Multiple Fan Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the function that allows different dishes to be cooked simultaneously without the smells mixing. Lasagna, croissants and brioches, tarts, cakes, etc. can be baked, thereby saving time and electricity.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>Multiple Moist Fan Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This adds more moisture to multiple fan normal cooking.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\"></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"><strong>ECO Cooking</strong></p><p style=\\\"text-align: justify;margin-bottom: 0px\\\" class=\\\"o_default_snippet_text\\\">This is the function that allows you to cook with significant savings on electricity consumption. With the ECO function, cooking times adapt to slow roasting, such as: braised meats, white meats, baked pasta, delicate pastries. This cooking cycle is not recommended for frozen foods.</p><p style=\\\"text-align: justify;margin-bottom: 0px\\\"></p><p style=\\\"margin-bottom: 0px\\\"><strong>California Proposition 65</strong></p><p style=\\\"margin-bottom: 0px\\\">WARNING: Cancer and Reproductive Harm</p><p style=\\\"margin-bottom: 0px\\\"><strong><a href=\\\"http://www.P65Warnings.ca.gov\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">www<span style=\\\"font-weight: normal\\\">.P65Warnings.ca.gov</span></a></strong></p></div>.<br><br><strong>Freight Charges May Apply</strong><br><br></div>      </div>      <h3 class=\\\"station-tabs-tabtitle\\\"><span id=\\\"station-tabs-tab_accessories\\\" class=\\\"station-tabs-tab\\\" aria-controls=\\\"station-tabs-tabpanel_accessories\\\" data-slug=\\\"accessories\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Accessories</span> </span></h3>      <div class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_accessories\\\" aria-labelledby=\\\"station-tabs-tab_accessories\\\" role=\\\"tabpanel\\\" aria-hidden=\\\"true\\\">         <div class=\\\"station-tabs-tabcontent\\\">             
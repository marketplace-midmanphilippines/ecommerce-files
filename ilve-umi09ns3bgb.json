\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2500 Watts</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o2be_burnerelementoutputn\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Burner/Element Output N4</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">2500 Watts</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o023_burnerelementoutputn\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Burner/Element Output N5</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">1800 Watts</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--Oven\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\"><br><b>Oven</b></th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\"></td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o1d6_ovencontroltype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Control Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">TFT Electronic Touchscreen</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o0f3_ovendoortype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Door Type</th>\\t\\t\\t<td class=\\\"woocommerce-product-attributes-item__value\\\">Triple Glass Door</td>\\t\\t</tr>\\t\\t\\t<tr class=\\\"woocommerce-product-attributes-item woocommerce-product-attributes-item--pa_o6de_ovencleaningtype\\\">\\t\\t\\t<th class=\\\"woocommerce-product-attributes-item__label\\\" scope=\\\"row\\\">Oven Cleaning Type</th>\\t\\t\\
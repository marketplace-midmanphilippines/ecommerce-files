br></th><td></td></tr><tr><th scope=\\\"row\\\">Exterior Width</th><td>36\\u2033</td></tr><tr><th scope=\\\"row\\\">Width</th><td>35 3/4\\u2033</td></tr><tr><th scope=\\\"row\\\">Depth</th><td>27\\u2033</td></tr><tr><th scope=\\\"row\\\">Height</th><td>38 1/2\\u2033</td></tr><tr><th scope=\\\"row\\\">Depth with Door Opened at 90 Degrees</th><td>40 1/2\\u2033</td></tr><tr><th scope=\\\"row\\\">Product Weight (lbs)</th><td>290</td></tr><tr><th scope=\\\"row\\\"><br><b>Fuel Type</b></br></th><td></td></tr><tr><th scope=\\\"row\\\">Fuel Type</th><td>Dual Fuel</td></tr><tr><th scope=\\\"row\\\">Gas Type</th><td>Natural Gas</td></tr><tr><th scope=\\\"row\\\"><br><b>Style</b></br></th><td></td></tr><tr><th scope=\\\"row\\\">Style</th><td>Freestanding</td></tr><tr><th scope=\\\"row\\\">Control Location</th><td>Front</td></tr><tr><th scope=\\\"row\\\"><br/><b>Capacity</b></th><td></td></tr><tr><th scope=\\\"row\\\">Total Capacity (cu. ft.)</th><td>3.5</td></tr><tr><th scope=\\\"row\\\">Number of Ovens</th><td>Single Oven</td></tr><tr><th scope=\\\"row\\\">Main Oven Capacity (cu. ft.)</th><td>3.5</td></tr><tr><th scope=\\\"row\\\"><br/><b>Cooking Surface</b></th><td></td></tr><tr><th scope=\\\"row\\\">Cooktop Configuration</th><td>6 Sealed Burners + Griddle</td></tr><tr><th scope=\\\"row\\\">Burner/Element Type</th><td>Sealed Burner</td></tr><tr><th scope=\\\"row\\\">Number of Burners/Elements</th><td>6</td></tr><tr><th scope=\\\"row\\\">Grill</th><td>No</td></tr><tr><th scope=\\\"row\\\">Griddle</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">French Top</th><td>No</td></tr><tr><th scope=\\\"row\\\">Highest Burner Output</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N1</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N2</th><td>7000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N3</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N4</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\
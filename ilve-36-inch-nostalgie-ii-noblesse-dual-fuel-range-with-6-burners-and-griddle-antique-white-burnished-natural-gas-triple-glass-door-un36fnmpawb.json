r><th scope=\\\"row\\\">Oven Control Type</th><td>Knobs</td></tr><tr><th scope=\\\"row\\\">Oven Door Type</th><td>Solid Door</td></tr><tr><th scope=\\\"row\\\">Oven Cleaning Type</th><td>Easy Clean Enamel Cavities</td></tr><tr><th scope=\\\"row\\\">Main Oven Type</th><td>UOV 80 M</td></tr><tr><th scope=\\\"row\\\">Interior Width</th><td>25 3/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Interior Height</th><td>14 3/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Interior Depth</th><td>16 1/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Oven Racks</th><td>2</td></tr><tr><th scope=\\\"row\\\"><br/><b>Technical Details</b></th><td></td></tr><tr><th scope=\\\"row\\\">Voltage</th><td>240</td></tr><tr><th scope=\\\"row\\\">Amps</th><td>15.4</td></tr><tr><th scope=\\\"row\\\"><br/><b>Certifications</b></th><td></td></tr><tr><th scope=\\\"row\\\">ADA Compliant</th><td>No</td></tr><tr><th scope=\\\"row\\\">Star-K Certified</th><td>No</td></tr><tr><th scope=\\\"row\\\"><br/><b>Warranty</b></th><td></td></tr><tr><th scope=\\\"row\\\">Warranty</th><td>2 Year Parts and Labor</td></tr><tr><th scope=\\\"row\\\"><br/><b>Features</b></th><td></td></tr><tr><th scope=\\\"row\\\">Sabbath Mode</th><td>No</td></tr><tr><th scope=\\\"row\\\">Display Type</th><td>LCD Display</td></tr><tr><th scope=\\\"row\\\">Drawer</th><td>Storage Drawer</td></tr><tr><th scope=\\\"row\\\">Timer</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">Rotisserie</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">Soft Close Door</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">Gas Conversion Kit Included</th><td>Yes</td></tr></table> </div> </div> <h3 class=\\\"station-tabs-tabtitle\\\"><span aria-controls=\\\"station-tabs-tabpanel_shipping-returns\\\" aria-selected=\\\"false\\\" class=\\\"station-tabs-tab\\\" data-slug=\\\"shipping-returns\\\" id=\\\"station-tabs-tab_shipping-returns\\\" role=\\\"tab\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Shipping/Returns</span> </span></h3> <div aria-hidden=\\\"true\\\" 
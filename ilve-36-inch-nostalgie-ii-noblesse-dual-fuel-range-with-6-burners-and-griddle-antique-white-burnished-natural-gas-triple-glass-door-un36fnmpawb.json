</tr><tr><th scope=\\\"row\\\">Total Capacity (cu. ft.)</th><td>3.5</td></tr><tr><th scope=\\\"row\\\">Number of Ovens</th><td>Single Oven</td></tr><tr><th scope=\\\"row\\\">Main Oven Capacity (cu. ft.)</th><td>3.5</td></tr><tr><th scope=\\\"row\\\"><br/><b>Cooking Surface</b></th><td></td></tr><tr><th scope=\\\"row\\\">Cooktop Configuration</th><td>6 Sealed Burners + Griddle</td></tr><tr><th scope=\\\"row\\\">Burner/Element Type</th><td>Sealed Burner</td></tr><tr><th scope=\\\"row\\\">Number of Burners/Elements</th><td>6</td></tr><tr><th scope=\\\"row\\\">Grill</th><td>No</td></tr><tr><th scope=\\\"row\\\">Griddle</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">French Top</th><td>No</td></tr><tr><th scope=\\\"row\\\">Highest Burner Output</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N1</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N2</th><td>7000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N3</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N4</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N5</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N6</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\"><br/><b>Oven</b></th><td></td></tr><tr><th scope=\\\"row\\\">Oven Control Type</th><td>Knobs</td></tr><tr><th scope=\\\"row\\\">Oven Door Type</th><td>Solid Door</td></tr><tr><th scope=\\\"row\\\">Oven Cleaning Type</th><td>Easy Clean Enamel Cavities</td></tr><tr><th scope=\\\"row\\\">Main Oven Type</th><td>UOV 80 M</td></tr><tr><th scope=\\\"row\\\">Interior Width</th><td>25 3/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Interior Height</th><td>14 3/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Interior Depth</th><td>16 1/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Oven Racks</th><td>2</td></tr><tr><th scope=\\\"row\\\"><br/><b>Technical Details</b></th><td></td></tr><tr><th scope=\\\"row\\\">Voltage</th><td>240</td></tr><t
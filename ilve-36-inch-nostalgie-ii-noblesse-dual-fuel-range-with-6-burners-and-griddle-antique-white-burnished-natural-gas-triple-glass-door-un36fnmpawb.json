td></tr><tr><th scope=\\\"row\\\"><br/><b>Capacity</b></th><td></td></tr><tr><th scope=\\\"row\\\">Total Capacity (cu. ft.)</th><td>3.5</td></tr><tr><th scope=\\\"row\\\">Number of Ovens</th><td>Single Oven</td></tr><tr><th scope=\\\"row\\\">Main Oven Capacity (cu. ft.)</th><td>3.5</td></tr><tr><th scope=\\\"row\\\"><br/><b>Cooking Surface</b></th><td></td></tr><tr><th scope=\\\"row\\\">Cooktop Configuration</th><td>6 Sealed Burners + Griddle</td></tr><tr><th scope=\\\"row\\\">Burner/Element Type</th><td>Sealed Burner</td></tr><tr><th scope=\\\"row\\\">Number of Burners/Elements</th><td>6</td></tr><tr><th scope=\\\"row\\\">Grill</th><td>No</td></tr><tr><th scope=\\\"row\\\">Griddle</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">French Top</th><td>No</td></tr><tr><th scope=\\\"row\\\">Highest Burner Output</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N1</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N2</th><td>7000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N3</th><td>25000 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N4</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N5</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\">Burner/Element Output N6</th><td>10500 BTU</td></tr><tr><th scope=\\\"row\\\"><br/><b>Oven</b></th><td></td></tr><tr><th scope=\\\"row\\\">Oven Control Type</th><td>Knobs</td></tr><tr><th scope=\\\"row\\\">Oven Door Type</th><td>Triple Glass Door</td></tr><tr><th scope=\\\"row\\\">Oven Cleaning Type</th><td>Easy Clean Enamel Cavities</td></tr><tr><th scope=\\\"row\\\">Main Oven Type</th><td>UOV 80 M</td></tr><tr><th scope=\\\"row\\\">Interior Width</th><td>25 3/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Interior Height</th><td>14 3/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Interior Depth</th><td>16 1/8\\u2033</td></tr><tr><th scope=\\\"row\\\">Oven Racks</th><td>2</td></tr><tr><th scope=\\\"row\\\"><br/><b>Technical Details</b></th><td></td></tr><tr><th scope=\\\"row\\\">Voltage</th><td>240</td></tr><tr><th scope=\\\"row\\\">Amps</th><td>15.4</td></tr><tr><th scope=\\\"row\\\"><br/><b>Certifications</b></th><td></td></tr><tr><th scope=\\\"row\\\">ADA Compliant</th><td>No</td></tr><tr><th scope=\\\"row\\\">Star-K Certified</th><td>No</td></tr><tr><th scope=\\\"row\\\"><br/><b>Warranty</b></th><td></td></tr><tr><th scope=\\\"row\\\">Warranty</th><td>2 Year Parts and Labor</td></tr><tr><th scope=\\\"row\\\"><br/><b>Features</b></th><td></td></tr><tr><th scope=\\\"row\\\">Sabbath Mode</th><td>No</td></tr><tr><th scope=\\\"row\\\">Display Type</th><td>LCD Display</td></tr><tr><th scope=\\\"row\\\">Drawer</th><td>Storage Drawer</td></tr><tr><th scope=\\\"row\\\">Timer</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">Rotisserie</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">Soft Close Door</th><td>Yes</td></tr><tr><th scope=\\\"row\\\">Gas Conversion Kit Included</th><td>Yes</td></tr></table> </div> </div> <h3 class=\\\"station-tabs-tabtitle\\\"><span aria-controls=\\\"station-tabs-tabpanel_shipping-returns\\\" aria-selected=\\\"false\\\" class=\\\"station-tabs-tab\\\" data-slug=\\\"shipping-returns\\\" id=\\\"station-tabs-tab_shipping-returns\\\" role=\\\"tab\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Shipping/Returns</span> </span></h3> <div aria-hidden=\\\"true\\\" aria-labelledby=\\\"station-tabs-tab_shipping-returns\\\" class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_shipping-returns\\\" role=\\\"tabpanel\\\"> <div class=\\\"station-tabs-tabcontent\\\">            Please review Castle &amp; Cabana's <strong>Return, Refund, Exchange</strong> and <strong>Shipping Policies</strong> carefully, as certain brands may have specific terms that differ from our general store policies.            <br/><br/>            For detailed information, please refer to the following sections:            <br/>            1. <strong><a href=\\\"/pages/refund-and-return-policy\
tabs-tabpanel_accessories\\\" aria-selected=\\\"false\\\" class=\\\"station-tabs-tab mod-last\\\" data-slug=\\\"accessories\\\" id=\\\"station-tabs-tab_accessories\\\" role=\\\"tab\\\" tabindex=\\\"-1\\\"> <span class=\\\"station-tabs-tabtext\\\">Accessories</span> </span></h3> <div aria-hidden=\\\"true\\\" aria-labelledby=\\\"station-tabs-tab_accessories\\\" class=\\\"station-tabs-tabpanel\\\" id=\\\"station-tabs-tabpanel_accessories\\\" role=\\\"tabpanel\\\"> <div class=\\\"station-tabs-tabcontent\\\"> </div> </div> \", \"Option1 Name\": \"Color\", \"Option1 Value\": \"Burgundy\", \"Option2 Name\": \"Trim\", \"Option2 Value\": \"Burnished\", \"Option3 Name\": \"Gas Type\", \"Option3 Value\": \"Liquid Propane\", \"Option4 Name\": \"Oven Door Type\", \"Option4 Value\": \"Solid Door\", \"Google Shopping / Google Product Category\": \"Home & Garden > Household Appliances\", \"Google Shopping / Gender\": \"Unisex\", \"Google Shopping / Age Group\": \"Adult\", \"Google Shopping / MPN\": \"8051202542968\", \"Google Shopping / Condition\": \"New\", \"Google Shopping / Custom Product\": \"\", \"Google Shopping / Custom Label 0\": \"\", \"Google Shopping / Custom Label 1\": \"\", \"Google Shopping / Custom Label 2\": \"\", \"Google Shopping / Custom Label 3\": \"\", \"Google Shopping / Custom Label 4\": \"\"}, {\"Variant Name\": \"ILVE - 36 inch Nostalgie II Noblesse Dual Fuel Range with 6 Burners and Griddle (Burgundy / Chrome / Natural Gas / Solid Door) - UN36FQNMPBUC\", \"Variant Inventory Tracker\": \"shopify\", \"Variant Inventory Qty\": \"10\", \"Variant SKU\": \"UN36FQNMPBUC\", \"Variant Image\": \"https://us.ilve.com/wp-content/uploads/UN36FQNMPBUC_p113157.jpg\", \"Variant All Images\": [\"https://us.ilve.com/wp-content/uploads/UN36FQNMPBUC_p113157.jpg\", \"https://us.ilve.com/wp-content/uploads/UN36FQNMPBUC_p113157_153741.jpg\", \"https://us.ilve.com/wp-content/uploads/UN36FQNMPBUC_p113157_153742.jpg\", \"https://us.ilve.com/wp-content/uploads/UN36FQNMPBUC_p113157_